# MiniMax API Key (必需)
MINIMAX_API_KEY=your-minimax-api-key-here

# Brave Search API Key (web_search tool 必需)
BRAVE_API_KEY=your-brave-api-key-here

# Function Calling
TOOL_MAX_RETRIES=1

# web_search 超时与缓存（缓存范围会被限制在 300~900 秒）
WEB_SEARCH_TIMEOUT_SECONDS=8
WEB_SEARCH_CACHE_TTL_SECONDS=600

# JWT Configuration
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (PostgreSQL recommended for production)
# 使用 Docker 本地开发:
#   docker-compose up -d
#   cp .env.docker .env
# PostgreSQL: postgresql://user:password@host:port/database_name
# SQLite (dev only): sqlite:///./ai_assistant.db
DATABASE_URL=postgresql://app_user:change_me@localhost:5432/ai_assistant

# 可选配置
# PYTHONUNBUFFERED=1
